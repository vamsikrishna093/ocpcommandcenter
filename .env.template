# ─────────────────────────────────────────────────────────────────────────
# N8N ORCHESTRATION (PRIMARY — All agents route through n8n)
# ─────────────────────────────────────────────────────────────────────────
# n8n is the SINGLE orchestration layer. Agents call n8n webhooks
# for ticket creation, updates, comments, approvals, and remediation.
# n8n decides which backends to invoke: xyOps, ServiceNow, Ansible, etc.
#
# Set ENABLE_N8N=false to fall back to direct xyOps calls (legacy mode).

ENABLE_N8N=true

# n8n Primary Orchestrator Connection
N8N_BASE_URL=http://n8n:5678
N8N_ORCHESTRATOR_TIMEOUT=10

# Legacy n8n webhook settings (kept for backward compatibility)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/incident
N8N_WEBHOOK_TOKEN=your-n8n-webhook-token
N8N_REQUEST_TIMEOUT=30
N8N_RETRY_ATTEMPTS=3
N8N_RETRY_DELAY_MS=1000

# Pattern Selection (choose one — used by legacy webhook client)
# Options: pre-enrichment | post-approval | smart-router
N8N_PATTERN=pre-enrichment

# Pattern-Specific URLs (legacy)
N8N_PRE_ENRICHMENT_WEBHOOK=http://n8n:5678/webhook/aiops/pre-enrichment
N8N_POST_APPROVAL_WEBHOOK=http://n8n:5678/webhook/aiops/post-approval
N8N_SMART_ROUTER_WEBHOOK=http://n8n:5678/webhook/aiops/smart-router

# Security
N8N_VERIFY_SSL=true
N8N_HMAC_SECRET=your-hmac-secret
N8N_API_KEY=your-n8n-api-key

# Observability
N8N_ENABLE_TRACING=true
N8N_TRACE_SAMPLE_RATE=1.0
N8N_LOG_LEVEL=INFO

# Fallback Behavior
N8N_FALLBACK_ON_TIMEOUT=true
N8N_FALLBACK_ON_ERROR=true

# Approval Settings
N8N_APPROVAL_TIMEOUT_SEC=1800

# ─────────────────────────────────────────────────────────────────────────
