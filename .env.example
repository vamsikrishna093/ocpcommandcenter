# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit real secrets.

# AI provider (one of these two is required for AI enrichment)
OPENAI_API_KEY=sk-proj-your-key-here
# CLAUDE_API_KEY=sk-ant-your-key-here   # alternative: Anthropic Claude

# AI model — override defaults
# AI_MODEL=gpt-4o                       # default for OpenAI
# AI_MODEL=claude-3-5-haiku-20241022    # default for Claude

# xyOps API key (Admin → API Keys → Create Key → paste here)
XYOPS_API_KEY=your-xyops-api-key-here

# Optional features
REQUIRE_APPROVAL=true
ANSIBLE_RUNNER_URL=http://ansible-runner:8080
