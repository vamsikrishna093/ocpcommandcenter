        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "zX-fwNcB5_oSR2jaMyRbtraPyj7rgUxP9bdCfiQ7pfk"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ type: $json.body.type || 'issue', status: $json.body.status || 'open', subject: $json.body.subject, body: $json.body.body, severity: $json.body.severity || 'warning', notify: $json.body.notify || [], custom_fields: { domain: $json.body.domain, alert_name: $json.body.alert_name || '', service_name: $json.body.service_name || '', bridge_trace_id: $json.body.bridge_trace_id || '' } }) }}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "xyops_create_ticket",
      "name": "xyOps: Create Ticket",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        400,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Build response with ticket info from xyOps\nconst xyopsResult = $input.first().json;\n\n// Extract ticket ID from various response formats\nconst ticketId = xyopsResult?.ticket?.id || xyopsResult?.id || xyopsResult?.ticket_id || '';\nconst ticketNum = xyopsResult?.ticket?.num || xyopsResult?.num || '';\n\nreturn [{\n  json: {\n    ticket_id: ticketId,\n    ticket_num: ticketNum,\n    ticket: xyopsResult?.ticket || xyopsResult || {},\n    domain: $('Webhook: Create Ticket').first().json.body.domain,\n    servicenow_mirrored: false,\n    orchestrator: 'n8n'\n  }\n}];"
      },
      "id": "create_ticket_response",
      "name": "Build Create Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Error fallback for create ticket\nconst input = $input.first().json;\nreturn [{\n  json: {\n    error: 'xyOps create_ticket failed',\n    n8n_unavailable: false,\n    details: input,\n    domain: $('Webhook: Create Ticket').first().json.body.domain\n  }\n}];"
      },
      "id": "create_ticket_error",
      "name": "Create Ticket Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        100
