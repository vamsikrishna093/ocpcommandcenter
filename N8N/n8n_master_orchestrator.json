      "parameters": {
        "jsCode": "// Notification hub — log the event and optionally forward\n// to Slack, email, PagerDuty, etc. via additional n8n nodes.\nconst payload = $input.first().json;\nconst ts = new Date().toISOString();\n\nconsole.log(`[NOTIFY] ${ts} domain=${payload.body.domain} event=${payload.body.event_type} alert=${payload.body.alert_name} service=${payload.body.service_name} ticket=${payload.body.ticket_id}`);\n\nreturn [{\n  json: {\n    status: 'notified',\n    event_type: payload.body.event_type,\n    domain: payload.body.domain,\n    timestamp: ts,\n    orchestrator: 'n8n'\n  }\n}];"
      },
