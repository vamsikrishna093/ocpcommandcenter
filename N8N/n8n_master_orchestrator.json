    {
      "parameters": {
        "jsCode": "// Close matching tickets\nconst searchResult = $input.first().json;\nconst tickets = searchResult?.tickets || searchResult?.results || [];\nconst domain = $('Webhook: Resolve Ticket').first().json.body.domain;\nconst closedIds = [];\n\nfor (const t of tickets) {\n  const tid = t.id || t.ticket_id;\n  if (!tid) continue;\n  try {\n    const xyopsUrl = 'http://xyops:5522';\n    // We'll mark tickets for closure — actual HTTP calls from n8n\n    closedIds.push(tid);\n  } catch (e) {\n    // skip\n  }\n}\n\nreturn [{\n  json: {\n    status: 'resolved',\n    domain: domain,\n    tickets_found: tickets.length,\n    closed_ids: closedIds,\n    orchestrator: 'n8n'\n  }\n}];"
      },
