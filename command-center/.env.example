# AIOps Command Center Environment Variables

# API Base URL — Compute Agent endpoint
# In Docker: http://compute-agent:9000
# Local dev: http://localhost:9000
REACT_APP_API_BASE_URL=http://localhost:9000

# WebSocket URL (optional, for real-time updates)
# REACT_APP_WS_URL=ws://localhost:9000/ws

# Polling interval in milliseconds (default: 3000)
# REACT_APP_POLL_INTERVAL=3000

# Enable debug logging
# REACT_APP_DEBUG=true
