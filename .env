# ═══════════════════════════════════════════════════════════════════════════
# AIOps Platform Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# 
# ⚠️  SENSITIVE FILE — NEVER COMMIT TO GITHUB!
# This file is protected by .gitignore and contains:
#    - API keys and tokens
#    - Database passwords
#    - Service URLs
#    - Configuration secrets
#
# Usage:
#   - Docker Compose: Automatically reads .env
#   - Local development: source .env
#
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# XYOPS INTEGRATION
# ─────────────────────────────────────────────────────────────────────────
# Get XYOPS_API_KEY from your xyOps admin dashboard
XYOPS_URL=http://xyops:5522
XYOPS_API_KEY=k9-jyIiC4dVK-t3gVMnUTRIk7iMM44zoBhG8RFDo0YE

# ─────────────────────────────────────────────────────────────────────────
# CORE SETTINGS
# ─────────────────────────────────────────────────────────────────────────
REQUIRE_APPROVAL=true
ANSIBLE_RUNNER_URL=http://ansible-runner:8080

# ─────────────────────────────────────────────────────────────────────────
# LOCAL LLM INTEGRATION (OLLAMA)
# ─────────────────────────────────────────────────────────────────────────
# Uses local LLM for cost savings and data privacy
# Models: llama2, llama3.2, qwen2, mistral, etc.
LOCAL_LLM_ENABLED=true
LOCAL_LLM_MODEL=qwen2:7b
OLLAMA_API_URL=http://host.docker.internal:11434
LOCAL_LLM_TIMEOUT=60
USE_EXTERNAL_LLM_FALLBACK=true

# DEPRECATED: External LLM APIs (no longer required)
# OPENAI_API_KEY=
# CLAUDE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# N8N INTEGRATION (OPTIONAL - Agentic Orchestration)
# ─────────────────────────────────────────────────────────────────────────
# Set ENABLE_N8N=true to trigger n8n workflows on alerts
# Leave as false to use standard processing (default)

# Around line 52, add this:

ENABLE_N8N=true
N8N_MASTER_ORCHESTRATOR_WEBHOOK=http://n8n:5678/webhook/aiops/master

# n8n Connection Configuration
N8N_WEBHOOK_URL=http://n8n:5678/webhook/incident
N8N_WEBHOOK_TOKEN=your-secure-webhook-token-here
N8N_REQUEST_TIMEOUT=30
N8N_RETRY_ATTEMPTS=3
N8N_RETRY_DELAY_MS=1000

# Pattern Selection (choose one: pre-enrichment | post-approval | smart-router)
N8N_PATTERN=pre-enrichment

# Pattern-Specific Webhook URLs
N8N_PRE_ENRICHMENT_WEBHOOK=http://n8n:5678/webhook/aiops/pre-enrichment
N8N_POST_APPROVAL_WEBHOOK=http://n8n:5678/webhook/aiops/post-approval
N8N_SMART_ROUTER_WEBHOOK=http://n8n:5678/webhook/aiops/smart-router


# Security Configuration
N8N_VERIFY_SSL=true
N8N_HMAC_SECRET=your-secure-hmac-secret-here
N8N_API_KEY=your-n8n-api-key-here

# Observability
N8N_ENABLE_TRACING=true
N8N_TRACE_SAMPLE_RATE=1.0
N8N_LOG_LEVEL=INFO

# Fallback Behavior (continue if n8n times out or errors)
N8N_FALLBACK_ON_TIMEOUT=true
N8N_FALLBACK_ON_ERROR=true

# Approval Workflow Settings
N8N_APPROVAL_TIMEOUT_SEC=1800

# ─────────────────────────────────────────────────────────────────────────
# SERVICENOW INTEGRATION (NEW)
# ─────────────────────────────────────────────────────────────────────────
# Create incidents in ServiceNow in parallel to xyOps tickets
# Set ENABLE_SERVICENOW=true to activate

ENABLE_SERVICENOW=false
SERVICENOW_URL=http://mock-servicenow:8080
SERVICENOW_USER=admin
SERVICENOW_PASSWORD=admin

# ─────────────────────────────────────────────────────────────────────────
# STREAMLIT UI CONFIGURATION (NEW)
# ─────────────────────────────────────────────────────────────────────────
# Agent API endpoints for the Streamlit observability dashboard

COMPUTE_AGENT_URL=http://compute-agent:9000
STORAGE_AGENT_URL=http://storage-agent:9001
OBS_INTELLIGENCE_URL=http://obs-intelligence:9100

# ─────────────────────────────────────────────────────────────────────────
# OBSERVABILITY BACKENDS
# ─────────────────────────────────────────────────────────────────────────
# Used by agents to fetch logs and metrics context

PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL: GitHub Integration (for PR audit trails)
# ─────────────────────────────────────────────────────────────────────────
# Format: owner/repo (e.g., myorg/myapp)
GITHUB_REPO=

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL: Email Notifications
# ─────────────────────────────────────────────────────────────────────────
# Comma-separated email addresses for ticket notifications
NOTIFY_EMAIL=

# ─────────────────────────────────────────────────────────────────────────
# OPENTELEMETRY CONFIGURATION (Advanced)
# ─────────────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_METRIC_EXPORT_INTERVAL_MS=15000


#3. Gitea PR Merge/Approve
